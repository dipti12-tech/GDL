<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" >

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:anyDensity="true" />


    <application
        android:name=".GilanisApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/appname_header"
        android:roundIcon="@drawable/appname_header"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GDL"
        tools:targetApi="31" >
        <activity
            android:name=".presentation.ui.activity.ImageViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.GDL" />
        <activity
            android:name=".presentation.ui.activity.MapPickerActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.activity.SplashScreenActivity"
            android:exported="true"
            android:theme="@style/Theme.GDL.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".presentation.ui.activity.SignUpActivity"></activity>
        <activity android:name=".presentation.ui.activity.SignInActivity"></activity>
        <activity android:name=".presentation.ui.activity.MainActivity"></activity>
<!--
        <activity android:name=".presentation.ui.activity.ProductByCategoryActivity"></activity>
-->
        <activity android:name=".presentation.ui.activity.ProductByCategoryDetailsActivity"></activity>
        <activity android:name=".presentation.ui.activity.ShoppingCartActivity"></activity>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyB3P6yk9eu3AgZMIzdnXHgx8kgSqiGBhsA" />

        <service
            android:name="com.example.app.presentation.notification.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>