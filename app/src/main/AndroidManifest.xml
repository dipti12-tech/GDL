        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GDL"
        tools:targetApi="31" >
        <activity
            android:name=".presentation.ui.activity.ImageViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.GDL" />
        <activity
            android:name=".presentation.ui.activity.MapPickerActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.activity.MainActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".presentation.ui.activity.SignInActivity" />
        <activity android:name=".presentation.ui.activity.SignUpActivity" />
        <activity android:name=".presentation.ui.activity.ProductByCategoryActivity" />
        <activity android:name=".presentation.ui.activity.ProductByCategoryDetailsActivity" />
        <activity android:name=".presentation.ui.activity.ShoppingCartActivity" />

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyBMb7-GJFu47x0IL3bMuRl_vtcX9tMlpBo" />
    </application>

</manifest>