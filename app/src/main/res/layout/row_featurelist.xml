<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/padding_8dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

   <androidx.cardview.widget.CardView
       android:layout_width="@dimen/card_width170dp"
       android:layout_height="@dimen/card_height"
       app:layout_constraintStart_toStartOf="parent"
       app:layout_constraintTop_toTopOf="parent">

       <ImageView
           android:id="@+id/featureItem"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:scaleType="centerCrop"
           android:src="@drawable/featureimage">
       </ImageView>

       <TextView
           android:id="@+id/featureName"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="@string/fruit"
           android:gravity="center"
           android:textColor="@color/white"
           android:textStyle="bold"
           android:layout_marginTop="@dimen/padding_50dp"
           android:textSize="@dimen/padding_24dp"
           android:shadowColor="#80000000"
           android:shadowDx="0"
           android:shadowDy="1"
           android:shadowRadius="4"
           >

       </TextView>
       <TextView
           android:id="@+id/featureDescription"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="@string/fruit_descrp"
           android:gravity="center"
           android:textColor="@color/white"
           android:layout_marginTop="100dp"
           android:textSize="@dimen/padding_default"
           android:maxLines="2"
           android:shadowColor="#80000000"
           android:shadowDx="0"
           android:shadowDy="1"
           android:shadowRadius="4"
           android:background="#66000000"
           >

       </TextView>
       <androidx.appcompat.widget.AppCompatButton
           android:id="@+id/btnShopNow"
           android:layout_width="120dp"
           android:layout_height="48dp"
           android:layout_gravity="center"
           android:gravity="center"
           android:textAllCaps="false"
           android:layout_marginBottom="@dimen/padding_8dp"
           android:layout_marginTop="@dimen/padding_70dp"
           android:background="@drawable/rounded_button_bg"
           android:text="@string/shopnow">

       </androidx.appcompat.widget.AppCompatButton>
   </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>