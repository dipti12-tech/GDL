<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomSheetLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:padding="16dp">

    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/close"
        android:contentDescription="Close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDeliveringTo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Delivering to "
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#000000"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutLocality"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:textAppearance="@style/textview"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvDeliveringTo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/tvLocality"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="14sp"
            android:textAppearance="@style/textview"
            />

        <TextView
            android:id="@+id/btnChangeLocation"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Change"
            android:gravity="center"
            android:layout_gravity="center"
            android:padding="@dimen/padding_8dp"
            android:background="@drawable/white_square_bg"
            android:textColor="@color/blue"
            android:textAppearance="@style/textview"
            android:textSize="11sp"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCheckout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Checkout"
        android:background="@drawable/rounded_btn_all"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:layout_marginTop="24dp"
        android:textAppearance="@style/textview"
        app:layout_constraintTop_toBottomOf="@id/layoutLocality"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
