<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    >

      <!-- Products list inside order card -->
       <LinearLayout
           android:id="@+id/productsContainer"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:orientation="vertical"
           android:layout_marginTop="12dp">

           <!-- Example product row (repeat per product) -->
           <LinearLayout
               android:id="@+id/productRow1"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:orientation="horizontal"
               android:paddingTop="8dp"
               android:paddingBottom="8dp">


               <!-- Title + size -->
               <LinearLayout
                   android:layout_width="0dp"
                   android:layout_height="wrap_content"
                   android:layout_weight="1"
                   android:orientation="vertical"
                   android:paddingStart="12dp">

                   <TextView
                       android:id="@+id/tvProductName"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text=""
                       android:textSize="14sp"
                       android:textColor="#222222" />


               </LinearLayout>

               <!-- Quantity badge -->
               <TextView
                   android:id="@+id/tvProductQty"
                   android:layout_width="36dp"
                   android:layout_height="36dp"
                   android:gravity="center"
                   android:layout_marginEnd="8dp"
                   android:background="@drawable/white_square_grey"
                   android:text=""
                   android:textSize="14sp"
                   android:textColor="#222222" />

               <!-- Price column -->
               <LinearLayout
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:orientation="vertical"
                   android:gravity="end">

                   <TextView
                       android:id="@+id/tvProductPrice"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="KES 4,560"
                       android:textAppearance="@style/header_title"
                       android:layout_gravity="center"
                       android:textSize="14sp"
                       android:textColor="#111111" />


               </LinearLayout>
           </LinearLayout>

       </LinearLayout>
</LinearLayout>
