<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="28dp">

        <include
            android:id="@+id/toolbar_header"
            layout="@layout/toolbar_header"
            android:layout_width="match_parent"
            android:layout_height="@dimen/padding_50dp"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/searchField"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/padding_8dp"
            android:layout_marginEnd="@dimen/padding_8dp"
            android:background="@drawable/search_field_bg"
            android:drawableStart="@drawable/ic_search"
            android:hint="Search"
            android:padding="10dp"
            android:paddingRight="@dimen/padding_8dp"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/toolbar_header"/>
        <View
            android:id="@+id/tv_view"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#C4C4C4"
            android:layout_marginTop="@dimen/padding_8dp"
            app:layout_constraintTop_toBottomOf="@+id/searchField">

        </View>
        <LinearLayout
            android:id="@+id/location"
            android:layout_width="match_parent"
            android:layout_height="@dimen/padding_50dp"
            android:background="@color/white"
            android:orientation="horizontal"
            android:weightSum="1"
            android:layout_gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/tv_view">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_8dp"
                android:layout_marginTop="@dimen/padding_8dp"
                android:layout_marginBottom="@dimen/padding_4dp"
                android:text="Deliver to:"
                android:textAppearance="@style/textview"
                android:textSize="14sp"
                android:layout_weight="0.80"
                />
            <TextView
                android:id="@+id/deliveryLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_8dp"
                android:layout_marginBottom="@dimen/padding_4dp"
                android:text=""
                android:textAppearance="@style/textview"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="#3B82F6"
                android:layout_weight="0.20"
                />

        </LinearLayout>
        <View
            android:id="@+id/view2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#C4C4C4"
            app:layout_constraintTop_toBottomOf="@+id/location"
            app:layout_constraintBottom_toTopOf="@+id/main_content">
        </View>


        <!-- Main content / fragment container -->
        <FrameLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/view2"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
