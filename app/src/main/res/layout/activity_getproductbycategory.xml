<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Groceries"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="@dimen/padding_24dp"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Category Chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/category_group"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:singleLine="false"
        android:layout_marginEnd="@dimen/padding_40dp"
        android:layout_marginStart="@dimen/padding_40dp"
        app:singleSelection="true"
        app:chipSpacing="8dp" />

    <!-- Filter and Sort Buttons -->
    <LinearLayout
        android:id="@+id/filterSortLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:weightSum="1"
        android:layout_marginEnd="@dimen/padding_20dp"
        android:layout_marginStart="@dimen/padding_20dp"
        android:layout_marginBottom="@dimen/padding_8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/category_group"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFilters"
            android:layout_width="100dp"
            android:layout_height="38dp"
            android:padding="@dimen/padding_4dp"
            android:text="Select filters"
            android:layout_gravity="start"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:layout_weight="0.5"
            android:drawableTint="@color/light_gray"
            android:drawableLeft="@drawable/filter"
            android:drawableRight="@drawable/arrow_down"
            android:drawablePadding="@dimen/padding_2dp"
            android:background="@drawable/white_square_bg"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSort"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_gravity="end"
            android:layout_weight="0.5"
            android:drawableTint="@color/light_gray"
            android:layout_marginStart="@dimen/padding_100dp"
            android:background="@drawable/white_square_bg"
            android:drawableRight="@drawable/arrow_down"
            android:padding="@dimen/padding_4dp"
            android:drawablePadding="@dimen/padding_2dp"
            android:textSize="10sp"
            android:text="Popularity"
            android:textAllCaps="false" />
    </LinearLayout>

    <!-- Selected Filters ChipGroup -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/active_filters"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/filterSortLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:chipSpacing="8dp"
        app:singleLine="false" />

    <!-- RecyclerView for items (optional section below this) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/selected_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginEnd="@dimen/padding_4dp"
        android:layout_marginStart="@dimen/padding_4dp"
        android:layout_marginTop="@dimen/padding_8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/active_filters">
    </androidx.recyclerview.widget.RecyclerView>
</androidx.constraintlayout.widget.ConstraintLayout>
