<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/title_shopbycategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cateory"
        android:layout_marginLeft="@dimen/padding_8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/shopbycategoryRecyclerView"
        android:textAppearance="@style/header_title"
        app:layout_constraintStart_toStartOf="parent"
>

    </TextView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/shopbycategoryRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="@dimen/padding_8dp"
        android:layout_marginTop="@dimen/padding_50dp"
        android:layout_marginRight="@dimen/padding_8dp"
        android:nestedScrollingEnabled="false"
        android:scrollbars="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_shopbycategory" />

</androidx.constraintlayout.widget.ConstraintLayout>