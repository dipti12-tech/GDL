<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:layout_marginEnd="@dimen/padding_8dp"
  >

    <androidx.constraintlayout.widget.ConstraintLayout
       android:id="@+id/constraint_details"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="@dimen/padding_24dp"
        >

        <!--&lt;!&ndash; NEW Badge &ndash;&gt;
        <TextView
            android:id="@+id/newBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEW"
            android:textColor="@android:color/white"
            android:background="@drawable/rounded_button_bg"
            android:padding="4dp"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>-->
        <!-- Product Image -->
        <ImageView
            android:id="@+id/productImage"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:scaleType="fitXY"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@drawable/pastpopularitem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            />

        <!-- Points Text -->

        <!-- Product Title -->
        <TextView
            android:id="@+id/pointsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Earn 5 points"
            android:visibility="gone"
            android:textColor="@android:color/holo_blue_dark"
            android:textSize="12sp"
            android:padding="@dimen/padding_2dp"
            android:layout_marginStart="@dimen/padding_8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/productImage" />

        <TextView
            android:id="@+id/productTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Smoked Paprika Dulce Sweet"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginStart="@dimen/padding_8dp"

            android:maxLines="2"
            android:padding="@dimen/padding_2dp"
            app:layout_constraintTop_toBottomOf="@id/pointsText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp"/>

        <!-- Weight -->
        <TextView
            android:id="@+id/productWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="70g"
            android:layout_marginStart="@dimen/padding_8dp"

            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:padding="@dimen/padding_2dp"

            app:layout_constraintTop_toBottomOf="@id/productTitle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="2dp"/>

        <!-- Star Rating -->
        <LinearLayout
            android:id="@+id/ratingLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/productWeight"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="4dp"
            android:padding="@dimen/padding_2dp"
            android:layout_marginStart="@dimen/padding_8dp"

            >

            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled"/>
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled"/>
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled"/>
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled"/>
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled"/>
        </LinearLayout>

        <!-- Price Section -->
        <LinearLayout
            android:id="@+id/priceLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/padding_2dp"
            android:layout_marginStart="@dimen/padding_8dp"

            app:layout_constraintTop_toBottomOf="@id/ratingLayout"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/currentPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KES 200"
                android:textColor="@android:color/holo_orange_dark"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/originalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KES 250"
                android:textColor="@android:color/darker_gray"
                android:textSize="12sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Special Deal Text -->
        <TextView
            android:id="@+id/specialDeal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 for KES 500"
            android:padding="@dimen/padding_2dp"
          android:layout_marginStart="@dimen/padding_default"
            android:textColor="@android:color/black"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/priceLayout"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="4dp"/>

        <!-- Add to Cart Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/addToCartButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Add to cart"
            android:background="@drawable/rounded_btn_all"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/specialDeal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginRight="@dimen/padding_default"
            android:layout_marginLeft="@dimen/padding_default"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="@dimen/padding_30dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
